{
  "name": "mighty-protocol",
  "version": "0.1.0",
  "type": "module",
  "description": "SDK and protocol helpers for Mighty Camera (Python, JavaScript, C++)",
  "license": "Apache-2.0",
  "main": "./js/index.js",
  "homepage": "https://github.com/asadm/mighty-protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/asadm/mighty-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/asadm/mighty-protocol/issues"
  },
  "keywords": [
    "mighty-camera",
    "vio",
    "slam",
    "sdk",
    "protocol"
  ],
  "exports": {
    ".": "./js/index.js",
    "./js": "./js/index.js",
    "./lib/loopclosure/*": "./lib/loopclosure/*",
    "./js/*": "./js/*"
  },
  "files": [
    "js",
    "lib/loopclosure",
    "cpp",
    "python",
    "README.md",
    "LICENSE",
    "PROTOCOL.md",
    "!python/**/__pycache__/**",
    "!python/**/*.egg-info/**",
    "!**/*.pyc"
  ],
  "engines": {
    "node": ">=16"
  }
}
